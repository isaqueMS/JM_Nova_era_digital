# JM NOVA ERA - Template de Variáveis de Ambiente
# RENOMEIE ESTE ARQUIVO PARA .env PARA USO LOCAL
# CONFIGURAR ESTAS VARIÁVEIS NO GITHUB SECRETS PARA DEPLOY

EXPO_PUBLIC_GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI
EXPO_PUBLIC_MIKWEB_TOKEN=SEU_TOKEN_MIKWEB_AQUI
EXPO_PUBLIC_EFI_CLIENT_ID=SEU_CLIENT_ID_EFI_AQUI
EXPO_PUBLIC_EFI_CLIENT_SECRET=SEU_CLIENT_SECRET_EFI_AQUI
